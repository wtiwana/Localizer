{
  "name": "localizer-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based local AI library monorepo",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev -w @localizer/demo",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
